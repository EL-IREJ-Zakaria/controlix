<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#0B1832"
                android:startColor="#040B17"
                android:centerColor="#071425" />
        </shape>
    </item>

    <item
        android:width="280dp"
        android:height="280dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:centerColor="#223B82F6"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <item
        android:width="132dp"
        android:height="132dp"
        android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="66dp"
                android:centerColor="#167C3AED"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>
</layer-list>
